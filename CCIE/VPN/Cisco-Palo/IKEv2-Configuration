function buildMap() {
  const cc = document.getElementById('c-col');
  const pc = document.getElementById('p-col');
  const co = document.getElementById('conn-col');
  M.forEach((m, i) => {
    const cb = document.createElement('div');
    cb.className = 'mblk'; cb.id = 'cb'+i;
    cb.innerHTML = `<div class="mnum">CISCO ${i+1}</div><div class="mname">${m.cn}</div><div class="msub">${m.cs}</div>`;
    cb.onclick = () => showM(i);
    cc.appendChild(cb);

    const pb = document.createElement('div');
    pb.className = 'mblk'; pb.id = 'pb'+i;
    pb.innerHTML = `<div class="mnum" style="color:${m.col}">PA ${i+1}</div><div class="mname">${m.pn}</div><div class="msub">${m.ps}</div>`;
    pb.onclick = () => showM(i);
    pc.appendChild(pb);

    const conn = document.createElement('div');
    conn.className = 'conn';
    conn.innerHTML = `<div class="cln" style="background:${m.col}"></div>`;
    co.appendChild(conn);
  });
}

function showM(i) {
  M.forEach((_, j) => {
    document.getElementById('cb'+j).style.cssText = '';
    document.getElementById('pb'+j).style.cssText = '';
  });
  const m = M[i];
  document.getElementById('cb'+i).style.cssText = `background:#f0f4ff;border-color:${m.col};`;
  document.getElementById('pb'+i).style.cssText = `background:#fff8f0;border-color:${m.col};`;
  document.getElementById('map-detail').innerHTML = `
    <div class="dpanel" style="border-color:${m.col};">
      <h3 style="color:${m.col};">${m.cn} &nbsp;↔&nbsp; ${m.pn}</h3>
      <div class="dnote">${m.note}</div>
      <div class="dgrid">
        <div class="dblk">
          <h4 style="color:#2b6cb0;">🔵 Cisco IOS</h4>
          <pre>${m.cc}</pre>
        </div>
        <div class="dblk">
          <h4 style="color:#c4390a;">🔴 Palo Alto</h4>
          <div class="ptag">📍 ${m.pp}</div>
          <pre>${m.pc}</pre>
        </div>
      </div>
    </div>`;
}

buildMap();
